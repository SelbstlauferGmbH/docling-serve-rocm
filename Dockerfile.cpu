# Extends the official CPU image with the SmolVLM model for picture description.
FROM ghcr.io/docling-project/docling-serve-cpu

USER 0
RUN docling-tools models download -o "${DOCLING_SERVE_ARTIFACTS_PATH}" smolvlm && \
    chown -R 1001:0 ${DOCLING_SERVE_ARTIFACTS_PATH} && \
    chmod -R g=u ${DOCLING_SERVE_ARTIFACTS_PATH}
USER 1001
